Screen {
    layout: vertical;
    background: $background;
}

.hidden {
    display: none;
}

* {
    scrollbar-size: 1 1;
    scrollbar-background: transparent;
    scrollbar-background-hover: $foreground 4%;
    scrollbar-background-active: $foreground 8%;
    scrollbar-color: $foreground 30%;
    scrollbar-color-hover: $primary 65%;
    scrollbar-color-active: $primary;
    scrollbar-corner-color: transparent;
}

#dev_topbar {
    width: 1fr;
    height: auto;
    background: $background;
    border: tall transparent;
    border-bottom: solid $foreground 10%;
    padding: 0 1;
    align: left middle;
}

#dev_topbar:focus-within {
    border: tall $secondary;
}

#dev_topbar_left,
#dev_topbar_right {
    width: 1fr;
    height: auto;
}

#dev_topbar_left {
    align: left middle;
}

#dev_topbar_center {
    width: auto;
    min-width: 19;
    height: auto;
    align: center middle;
}

#dev_topbar_right {
    align: right middle;
}

#dev_nav_dot {
    width: 1;
    margin-right: 1;
    color: $primary;
    text-style: bold;
}

#dev_theme_select {
    width: 20;
    min-width: 20;
    margin-right: 1;
    border: none;
    background: transparent;
}

#dev_theme_select SelectCurrent {
    border: none;
    color: $foreground;
    background: transparent;
    padding: 0 1;
}

#dev_theme_select SelectCurrent Static#label {
    color: $foreground 70%;
}

#dev_theme_select SelectCurrent.-has-value Static#label {
    color: $foreground;
}

#dev_theme_select SelectOverlay {
    min-width: 20;
    width: 20;
    background: $background;
    color: $foreground;
    border: tall $nb-border-subtle;
}

#dev_theme_select SelectOverlay > .option-list--option-highlighted {
    color: $foreground;
    background: $panel;
    text-style: bold;
}

#dev_title {
    width: auto;
    margin-right: 1;
    color: $foreground;
    text-style: bold;
}

#dev_title_suffix {
    width: auto;
    color: $secondary;
}

#dev_logo {
    width: auto;
    margin: 0 1;
    color: $primary;
    text-style: bold;
    text-align: center;
    text-wrap: nowrap;
}

#dev_clock {
    width: auto;
    min-width: 8;
    margin-right: 1;
    color: $text-muted;
}

#dev_connection_badge {
    width: 1;
    margin-right: 1;
    color: $nb-secondary-text;
    text-style: bold;
}

#dev_connection_badge.-checking {
    color: $nb-warning-text;
}

#dev_connection_badge.-ok {
    color: $nb-success-text;
}

#dev_connection_badge.-warning {
    color: $nb-warning-text;
}

#dev_connection_badge.-error {
    color: $nb-danger-text;
}

#dev_close_button {
    width: auto;
    min-width: 0;
    background: $error;
    color: $background;
    border: none;
    text-style: bold;
}

#dev_request_bar {
    width: 1fr;
    height: auto;
    padding: 0 1 1 1;
    border-bottom: solid $foreground 10%;
    background: $background;
}

#dev_method_select {
    width: 12;
    min-width: 12;
    margin-right: 1;
    border: none;
    background: transparent;
}

#dev_method_select SelectCurrent {
    border: tall transparent;
    background: $panel;
    color: $foreground;
    padding: 0 1;
    text-style: bold;
}

#dev_method_select SelectCurrent:focus {
    border: tall $primary;
}

#dev_path_input {
    width: 1fr;
    margin-right: 1;
    border: tall transparent;
    background: transparent;
}

#dev_path_input:focus {
    border: tall $primary;
    background: $primary 7%;
}

#dev_send_button {
    width: 12;
    background: $primary;
    color: $background;
    border: none;
    text-style: bold;
}

#dev_shell {
    height: 1fr;
}

#dev_sidebar {
    width: 34;
    min-width: 26;
    max-width: 35%;
    background: $background;
    border-right: tall $foreground 10%;
    padding: 0 1;
    overflow: hidden scroll;
    scrollbar-size: 0 0;
}

#dev_sidebar_title {
    padding: 1 0 0 0;
    color: $secondary;
    text-style: bold;
}

#dev_help {
    padding: 1 0;
    color: $text-muted;
}

#dev_main {
    width: 1fr;
    padding: 0 1 1 1;
    background: $background;
}

#dev_context {
    padding: 1 0;
    color: $foreground;
    text-style: bold;
}

#dev_columns {
    height: 1fr;
}

#dev_request_panel,
#dev_response_panel {
    width: 1fr;
    height: 1fr;
    border: tall $nb-border-subtle;
    background: $surface;
}

#dev_request_panel {
    margin-right: 1;
}

#dev_request_tabs,
#dev_response_tabs {
    height: 1fr;
}

#dev_operation_search,
#dev_query_input {
    margin: 1;
    border: tall transparent;
    background: $panel;
}

#dev_operation_search:focus,
#dev_query_input:focus {
    border: tall $secondary;
}

#dev_operation_list {
    height: 1fr;
    margin: 0 1;
    background: $background;
    border: tall $nb-border-subtle;
}

#dev_operation_summary,
#dev_query_help,
#dev_body_help,
#dev_response_summary {
    padding: 1;
    color: $text-muted;
}

#dev_body_editor,
#dev_response_body,
#dev_response_headers {
    height: 1fr;
    margin: 1;
    background: $background;
    border: tall $nb-border-subtle;
}

#dev_response_meta {
    height: auto;
    padding: 1;
    border-bottom: solid $foreground 10%;
    background: $panel;
}

#dev_response_status {
    width: 1fr;
    color: $foreground;
    text-style: bold;
}

#dev_response_timing,
#dev_response_size {
    width: auto;
    min-width: 10;
    color: $text-muted;
    content-align: right middle;
}

Tree {
    background: transparent;
    color: $foreground;
}

Tree:focus {
    border: tall $primary;
}

OptionList {
    background: $background;
    color: $foreground;
    border: tall $nb-border-subtle;
}

OptionList:focus {
    border: tall $primary;
}

OptionList > .option-list--option-highlighted {
    color: $foreground;
    background: $panel;
    text-style: bold;
}

TabbedContent {
    background: $surface;
}

TabPane {
    padding: 0;
    background: $surface;
}
